{
	"name": "authortopia",
	"version": "1.0.0",
	"description": "Authortopia: demonstrates global and tabular trigger groups in pict-section-form",
	"main": "Authortopia-Application.js",
	"scripts": {
		"start": "node Bookstore-Data-Server.js",
		"build": "npx quack build && npx quack copy",
		"serve": "node Bookstore-Data-Server.js"
	},
	"author": "steven",
	"license": "MIT",
	"devDependencies": {
	},
	"copyFilesSettings": {
		"whenFileExists": "overwrite"
	},
	"copyFiles": [
		{
			"from": "./html/*",
			"to": "./dist/"
		},
		{
			"from": "../../node_modules/pict/dist/*",
			"to": "./dist/"
		}
	]
}
